# Copy these values into the deployed backend environment.
# Do not point production CORS/payment redirects at localhost.

NODE_ENV=production
PORT=5000

FRONTEND_URL=https://YOUR-VERCEL-DOMAIN
CORS_ORIGINS=https://YOUR-VERCEL-DOMAIN

MONGODB_URI=your_production_mongodb_uri

FIREBASE_PROJECT_ID=dormitorymanagement-caps-572cf
FIREBASE_CLIENT_EMAIL=your_firebase_admin_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_WEB_API_KEY=your_firebase_web_api_key
FIREBASE_API_KEY=your_firebase_web_api_key

JWT_SECRET=use_a_long_random_secret
SESSION_SECRET=use_a_long_random_secret
EMAIL_OTP_SECRET=use_a_long_random_secret
PORTAL_SESSION_TTL_HOURS=24

# Required for applicant/tenant OTP emails and other transactional email.
EMAIL_USER=your_sender_gmail_or_workspace_account
EMAIL_PASSWORD=your_app_password
EMAIL_OTP_EXPIRY_MINUTES=10
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=60
EMAIL_OTP_MAX_ATTEMPTS=5

PAYMONGO_SECRET_KEY=your_paymongo_secret_key
PAYMONGO_PUBLIC_KEY=your_paymongo_public_key
PAYMONGO_WEBHOOK_SECRET=your_paymongo_webhook_secret

# Required for applicant ID OCR validation (Google Vision API).
# Option A — set this to the absolute path of the key file on the production server:
#   GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/google-vision-key.json
# Option B — place the key file at server/config/google-vision-key.json (auto-detected, no env var needed).
# If neither is configured, ID validation degrades gracefully to manual_review status.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-vision-key.json

# Optional for Reports & Analytics AI summaries.
# Use "gemini" for Google Gemini-backed summaries or "heuristic" for local rule-based summaries.
# Gemini has a free tier for small/testing use, but production deployments may need paid tier/quota.
AI_INSIGHTS_PROVIDER=gemini
# Reuse GOOGLE_AI_API_KEY if you already configured Gemini for chatbot features.
# GEMINI_API_KEY is also supported and takes precedence when both are set.
GOOGLE_AI_API_KEY=your_google_ai_studio_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
