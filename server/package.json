{
  "name": "lilycrest-server",
  "version": "1.0.0",
  "description": "Backend API for Lilycrest Dormitory Management",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "kill-port": "node scripts/kill-port.js",
    "restart": "node scripts/kill-port.js && node server.js",
    "utility:diagnose": "node scripts/diagnose_utility_sync.mjs",
    "utility:repair": "node scripts/repair_utility_sync.mjs",
    "utility:cleanup-zero-segments": "node scripts/cleanup_zero_consumption_segments.mjs",
    "utility:cleanup-zero-segments:write": "node scripts/cleanup_zero_consumption_segments.mjs --write",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "keywords": [
    "express",
    "firebase",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "capstone-website": "file:..",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dayjs": "^1.11.20",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.0",
    "firebase-admin": "^12.0.0",
    "helmet": "^8.1.0",
    "mongoose": "^8.22.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.13",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "xss": "^1.0.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "jest": "^30.3.0",
    "nodemon": "^3.0.1"
  }
}
